{
    "openapi": "3.0.3",
    "info": {
        "title": "CompanionX API Documentation",
        "description": "API definition for CompanionX: An AI-Powered Mental Wellness Platform.\n\n### Authorization\nProtected routes require a Bearer Token (Laravel Sanctum).\nSend the header: `Authorization: Bearer {token}`",
        "version": "1.1.0",
        "contact": {
            "name": "CompanionX Tech Team"
        }
    },
    "servers": [
        {
            "url": "http://companionx-api.test/api",
            "description": "Local Development Server (Herd)"
        }
    ],
    "tags": [
        { "name": "Auth", "description": "User identity and session management" },
        { "name": "Onboarding", "description": "Initial mental health profiling" },
        { "name": "Journal", "description": "Patient mood tracking and history" },
        { "name": "Dashboard", "description": "AI matching and analytics" }
    ],
    "paths": {
        "/register": {
            "post": {
                "tags": ["Auth"],
                "summary": "Register a new Patient",
                "operationId": "register",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": { "schema": { "$ref": "#/components/schemas/RegisterRequest" } }
                    }
                },
                "responses": {
                    "201": { "description": "User created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthSuccessResponse" } } } },
                    "422": { "description": "Validation Error" }
                }
            }
        },
        "/login": {
            "post": {
                "tags": ["Auth"],
                "summary": "User Login",
                "operationId": "login",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": { "schema": { "$ref": "#/components/schemas/LoginRequest" } }
                    }
                },
                "responses": {
                    "200": { "description": "Successful Login", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthSuccessResponse" } } } },
                    "401": { "description": "Invalid Credentials" }
                }
            }
        },
        "/user": {
            "get": {
                "tags": ["Auth"],
                "summary": "Get authenticated user profile",
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": { "description": "Success", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } }
                }
            }
        },
        "/onboarding": {
            "post": {
                "tags": ["Onboarding"],
                "summary": "Save profiling answers and trigger AI Match",
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "answers": { "type": "object", "example": { "primary_concern": "Anxiety", "mood_scale": 4 } }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Answers saved, AI process started" }
                }
            }
        },
        "/dashboard/recommendations": {
            "get": {
                "tags": ["Dashboard"],
                "summary": "Fetch AI-suggested consultants",
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": {
                        "description": "List of consultants with AI match reasons",
                        "content": {
                            "application/json": {
                                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ConsultantMatch" } }
                            }
                        }
                    }
                }
            }
        },
        "/journal": {
            "get": {
                "tags": ["Journal"],
                "summary": "List user's mood journal entries",
                "security": [{ "bearerAuth": [] }],
                "responses": {
                    "200": {
                        "description": "History of journals",
                        "content": {
                            "application/json": {
                                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/JournalEntry" } }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": ["Journal"],
                "summary": "Create new journal entry",
                "security": [{ "bearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": { "schema": { "$ref": "#/components/schemas/JournalRequest" } }
                    }
                },
                "responses": {
                    "201": { "description": "Saved" }
                }
            }
        },
        "/journal/{id}": {
            "put": {
                "tags": ["Journal"],
                "summary": "Update an entry",
                "security": [{ "bearerAuth": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "requestBody": {
                    "required": true,
                    "content": { "application/json": { "schema": { "$ref": "#/components/schemas/JournalRequest" } } }
                },
                "responses": {
                    "200": { "description": "Updated" }
                }
            },
            "delete": {
                "tags": ["Journal"],
                "summary": "Delete an entry",
                "security": [{ "bearerAuth": [] }],
                "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
                "responses": {
                    "200": { "description": "Deleted" }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "Sanctum" }
        },
        "schemas": {
            "User": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer" },
                    "first_name": { "type": "string" },
                    "last_name": { "type": "string" },
                    "email": { "type": "string" },
                    "system_role": { "type": "string", "enum": ["patient", "consultant", "admin"] },
                    "onboarding_completed": { "type": "boolean" }
                }
            },
            "RegisterRequest": {
                "type": "object",
                "required": ["first_name", "last_name", "email", "phone", "password", "password_confirmation", "dob"],
                "properties": {
                    "first_name": { "type": "string" },
                    "last_name": { "type": "string" },
                    "email": { "type": "string", "format": "email" },
                    "phone": { "type": "string" },
                    "password": { "type": "string" },
                    "password_confirmation": { "type": "string" },
                    "dob": { "type": "string", "format": "date" },
                    "gender": { "type": "string" },
                    "guardian_contact": { "type": "string" }
                }
            },
            "LoginRequest": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                    "email": { "type": "string" },
                    "password": { "type": "string" }
                }
            },
            "AuthSuccessResponse": {
                "type": "object",
                "properties": {
                    "user": { "$ref": "#/components/schemas/User" },
                    "token": { "type": "string" }
                }
            },
            "JournalRequest": {
                "type": "object",
                "required": ["emoji_mood"],
                "properties": {
                    "emoji_mood": { "type": "string", "example": "😊" },
                    "text_note": { "type": "string" }
                }
            },
            "JournalEntry": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer" },
                    "emoji_mood": { "type": "string" },
                    "text_note": { "type": "string" },
                    "sentiment_score": { "type": "number", "nullable": true },
                    "is_at_risk": { "type": "boolean" },
                    "created_at": { "type": "string", "format": "date-time" }
                }
            },
            "ConsultantMatch": {
                "type": "object",
                "properties": {
                    "id": { "type": "integer" },
                    "specialization": { "type": "string" },
                    "bio": { "type": "string" },
                    "base_rate_bdt": { "type": "number" },
                    "match_reason": { "type": "string", "description": "The AI provided explanation for the match" },
                    "user": {
                        "type": "object",
                        "properties": {
                            "first_name": { "type": "string" },
                            "last_name": { "type": "string" }
                        }
                    }
                }
            }
        }
    }
}